{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Configure RenderLaz",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                ".",
                "-B",
                "build-mingw",
                "-G",
                "MinGW Makefiles",
                "-DCMAKE_PREFIX_PATH=D:/Qt/6.10.1/mingw_64",
                "-DCMAKE_C_COMPILER=D:/Qt/Tools/mingw1310_64/bin/gcc.exe",
                "-DCMAKE_CXX_COMPILER=D:/Qt/Tools/mingw1310_64/bin/g++.exe",
                "-DCMAKE_MAKE_PROGRAM=D:/Qt/Tools/mingw1310_64/bin/mingw32-make.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Build RenderLaz",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build-mingw"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "Configure RenderLaz",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}
