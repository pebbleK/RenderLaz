{
    "configurations": [
        {
            "name": "Qt macOS",
            "compilerPath": "/usr/bin/clang++",
            "cppStandard": "c++17",
            "intelliSenseMode": "macos-clang-arm64",
            "includePath": [
                "${workspaceFolder}/src",
                "/opt/homebrew/include",
                "/opt/homebrew/include/QtCore",
                "/opt/homebrew/include/QtGui",
                "/opt/homebrew/include/QtWidgets"
            ],
            "defines": [
                "QT_CORE_LIB",
                "QT_GUI_LIB",
                "QT_WIDGETS_LIB"
            ]
        }
    ],
    "version": 4
}
